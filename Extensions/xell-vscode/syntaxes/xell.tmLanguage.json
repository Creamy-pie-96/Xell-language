{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Xell",
  "scopeName": "source.xell",
  "fileTypes": [
    "xel",
    "nxel"
  ],
  "comment": "AUTO-GENERATED by gen_xell_grammar.py \u2014 DO NOT EDIT MANUALLY. Re-run: python3 Extensions/gen_xell_grammar.py",
  "patterns": [
    {
      "include": "#block-comment"
    },
    {
      "include": "#line-comment"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#for-loop"
    },
    {
      "include": "#for-in-loop"
    },
    {
      "include": "#bring-statement"
    },
    {
      "include": "#fn-declaration-keywords"
    },
    {
      "include": "#return-keywords"
    },
    {
      "include": "#conditional-keywords"
    },
    {
      "include": "#loop-keywords"
    },
    {
      "include": "#control-flow-keywords"
    },
    {
      "include": "#error-keywords"
    },
    {
      "include": "#binding-keywords"
    },
    {
      "include": "#import-keywords"
    },
    {
      "include": "#module-keywords"
    },
    {
      "include": "#oop-declaration-keywords"
    },
    {
      "include": "#oop-modifier-keywords"
    },
    {
      "include": "#access-keywords"
    },
    {
      "include": "#generator-keywords"
    },
    {
      "include": "#async-keywords"
    },
    {
      "include": "#logical-operators"
    },
    {
      "include": "#comparison-word-operators"
    },
    {
      "include": "#boolean-constants"
    },
    {
      "include": "#none-constant"
    },
    {
      "include": "#special-keywords"
    },
    {
      "include": "#archive-builtins"
    },
    {
      "include": "#bytes-builtins"
    },
    {
      "include": "#casting-builtins"
    },
    {
      "include": "#collection-builtins"
    },
    {
      "include": "#datetime-builtins"
    },
    {
      "include": "#fs-builtins"
    },
    {
      "include": "#generator-builtins"
    },
    {
      "include": "#hash-builtins"
    },
    {
      "include": "#io-builtins"
    },
    {
      "include": "#json-builtins"
    },
    {
      "include": "#list-builtins"
    },
    {
      "include": "#map-builtins"
    },
    {
      "include": "#math-builtins"
    },
    {
      "include": "#network-builtins"
    },
    {
      "include": "#os-builtins"
    },
    {
      "include": "#process-builtins"
    },
    {
      "include": "#regex-builtins"
    },
    {
      "include": "#shell-builtins"
    },
    {
      "include": "#string-builtins"
    },
    {
      "include": "#sysmon-builtins"
    },
    {
      "include": "#textproc-builtins"
    },
    {
      "include": "#type-builtins"
    },
    {
      "include": "#util-builtins"
    },
    {
      "include": "#arrow-access"
    },
    {
      "include": "#comparison-operators"
    },
    {
      "include": "#increment-operators"
    },
    {
      "include": "#assignment-operator"
    },
    {
      "include": "#arithmetic-operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#method-call"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#semicolon-terminator"
    },
    {
      "include": "#dot-terminator"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "block-comment": {
      "name": "comment.block.arrow.xell",
      "begin": "-->",
      "end": "<--",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.begin.xell"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.comment.end.xell"
        }
      }
    },
    "line-comment": {
      "name": "comment.line.number-sign.xell",
      "match": "#.*$"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.xell",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "string.interpolation.xell",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.xell"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.xell"
                }
              },
              "patterns": [
                {
                  "include": "source.xell"
                }
              ]
            },
            {
              "name": "constant.character.escape.xell",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "function-definition": {
      "comment": "fn name(param1, param2):",
      "patterns": [
        {
          "name": "meta.function.definition.xell",
          "begin": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.function.xell"
            },
            "2": {
              "name": "entity.name.function.definition.xell"
            }
          },
          "end": "\\)\\s*(:|\\.)",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.function.xell"
            }
          },
          "patterns": [
            {
              "name": "variable.parameter.xell",
              "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
            },
            {
              "name": "punctuation.separator.parameter.xell",
              "match": ","
            }
          ]
        }
      ]
    },
    "for-loop": {
      "comment": "for i in range(...)",
      "patterns": [
        {
          "match": "\\b(for)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(in)\\s+(range)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.flow.xell"
            },
            "2": {
              "name": "variable.other.loop.xell"
            },
            "3": {
              "name": "keyword.control.loop.xell"
            },
            "4": {
              "name": "support.function.builtin.xell"
            }
          }
        }
      ]
    },
    "for-in-loop": {
      "comment": "for item in collection",
      "patterns": [
        {
          "match": "\\b(for)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(in)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.flow.xell"
            },
            "2": {
              "name": "variable.other.loop.xell"
            },
            "3": {
              "name": "keyword.control.loop.xell"
            }
          }
        }
      ]
    },
    "bring-statement": {
      "comment": "bring name from 'file' as alias",
      "patterns": [
        {
          "match": "\\b(bring)\\s+(.+?)\\s+(from)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.xell"
            },
            "3": {
              "name": "keyword.control.import.xell"
            }
          }
        }
      ]
    },
    "fn-declaration-keywords": {
      "comment": "Function declaration: fn",
      "patterns": [
        {
          "name": "keyword.declaration.function.xell",
          "match": "\\b(fn)\\b"
        }
      ]
    },
    "return-keywords": {
      "comment": "Return: give",
      "patterns": [
        {
          "name": "keyword.control.return.xell",
          "match": "\\b(give)\\b"
        }
      ]
    },
    "conditional-keywords": {
      "comment": "Conditional: elif, else, if, incase",
      "patterns": [
        {
          "name": "keyword.control.conditional.xell",
          "match": "\\b(incase|elif|else|if)\\b"
        }
      ]
    },
    "loop-keywords": {
      "comment": "Loop: for, in, loop, while",
      "patterns": [
        {
          "name": "keyword.control.loop.xell",
          "match": "\\b(range|while|loop|for|in)\\b"
        }
      ]
    },
    "control-flow-keywords": {
      "comment": "Control flow: break, continue",
      "patterns": [
        {
          "name": "keyword.control.flow.xell",
          "match": "\\b(continue|break)\\b"
        }
      ]
    },
    "error-keywords": {
      "comment": "Error handling: catch, finally, try",
      "patterns": [
        {
          "name": "keyword.control.trycatch.xell",
          "match": "\\b(finally|catch|try)\\b"
        }
      ]
    },
    "binding-keywords": {
      "comment": "Binding: be, immutable, let",
      "patterns": [
        {
          "name": "keyword.other.binding.xell",
          "match": "\\b(immutable|let|be)\\b"
        }
      ]
    },
    "import-keywords": {
      "comment": "Import: as, bring, from",
      "patterns": [
        {
          "name": "keyword.control.import.xell",
          "match": "\\b(bring|from|as)\\b"
        }
      ]
    },
    "module-keywords": {
      "comment": "Module: export, module, requires",
      "patterns": [
        {
          "name": "keyword.control.module.xell",
          "match": "\\b(requires|export|module)\\b"
        }
      ]
    },
    "oop-declaration-keywords": {
      "comment": "OOP declaration: abstract, class, enum, interface, mixin, struct",
      "patterns": [
        {
          "name": "keyword.declaration.type.xell",
          "match": "\\b(interface|abstract|struct|class|mixin|enum)\\b"
        }
      ]
    },
    "oop-modifier-keywords": {
      "comment": "OOP modifier: implements, inherits, with",
      "patterns": [
        {
          "name": "keyword.other.modifier.xell",
          "match": "\\b(implements|inherits|with)\\b"
        }
      ]
    },
    "access-keywords": {
      "comment": "Access: private, protected, public, static",
      "patterns": [
        {
          "name": "storage.modifier.xell",
          "match": "\\b(protected|private|public|static)\\b"
        }
      ]
    },
    "generator-keywords": {
      "comment": "Generator: yield",
      "patterns": [
        {
          "name": "keyword.control.yield.xell",
          "match": "\\b(yield)\\b"
        }
      ]
    },
    "async-keywords": {
      "comment": "Async: async, await",
      "patterns": [
        {
          "name": "keyword.control.async.xell",
          "match": "\\b(async|await)\\b"
        }
      ]
    },
    "logical-operators": {
      "comment": "Logical: and, not, or",
      "patterns": [
        {
          "name": "keyword.operator.logical.xell",
          "match": "\\b(and|not|or)\\b"
        }
      ]
    },
    "comparison-word-operators": {
      "comment": "Comparison words: eq, ge, gt, is, le, lt, ne",
      "patterns": [
        {
          "name": "keyword.operator.comparison.word.xell",
          "match": "\\b(eq|ge|gt|is|le|lt|ne)\\b"
        }
      ]
    },
    "special-keywords": {
      "comment": "Special: of",
      "patterns": [
        {
          "name": "keyword.other.special.xell",
          "match": "\\b(of)\\b"
        }
      ]
    },
    "boolean-constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.xell",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.xell",
          "match": "\\bfalse\\b"
        }
      ]
    },
    "none-constant": {
      "patterns": [
        {
          "name": "constant.language.none.xell",
          "match": "\\bnone\\b"
        }
      ]
    },
    "archive-builtins": {
      "comment": "ARCHIVE builtins: bunzip2_decompress, bzip2_compress, gunzip_decompress, gzip_compress, tar_create, tar_extract, unzip_archive, xz_compress, xz_decompress, zip_archive",
      "patterns": [
        {
          "name": "support.function.archive.xell",
          "match": "\\b(bunzip2_decompress|bzip2_compress|gunzip_decompress|gzip_compress|tar_create|tar_extract|unzip_archive|xz_compress|xz_decompress|zip_archive)\\b(?=\\s*\\()"
        }
      ]
    },
    "bytes-builtins": {
      "comment": "BYTES builtins: byte_at, byte_len, bytes, bytes, bytes_concat, bytes_slice, decode, encode, to_bytes",
      "patterns": [
        {
          "name": "support.function.bytes.xell",
          "match": "\\b(byte_at|byte_len|bytes|bytes|bytes_concat|bytes_slice|decode|encode|to_bytes)\\b(?=\\s*\\()"
        }
      ]
    },
    "casting-builtins": {
      "comment": "CASTING builtins: Bool, Complex, Float, Int, List, Set, String, Tuple, auto, iSet, number",
      "patterns": [
        {
          "name": "support.function.casting.xell",
          "match": "\\b(Bool|Complex|Float|Int|List|Set|String|Tuple|auto|iSet|number)\\b(?=\\s*\\()"
        }
      ]
    },
    "collection-builtins": {
      "comment": "COLLECTION builtins: add, contains, diff, has, intersect, keys, len, pop, push, range, remove, set, to_list, to_set, to_tuple, union_set, values",
      "patterns": [
        {
          "name": "support.function.builtin.xell",
          "match": "\\b(add|contains|diff|has|intersect|keys|len|pop|push|range|remove|set|to_list|to_set|to_tuple|union_set|values)\\b(?=\\s*\\()"
        }
      ]
    },
    "datetime-builtins": {
      "comment": "DATETIME builtins: format_date, now, parse_date, sleep, sleep_sec, time_since, timestamp, timestamp_ms",
      "patterns": [
        {
          "name": "support.function.datetime.xell",
          "match": "\\b(format_date|now|parse_date|sleep|sleep_sec|time_since|timestamp|timestamp_ms)\\b(?=\\s*\\()"
        }
      ]
    },
    "fs-builtins": {
      "comment": "FS builtins: cat, chgrp, chmod, chown, created_time, disk_free, disk_usage, extension, file_diff, find, find_regex, glob, hardlink, home_dir, is_absolute, is_symlink, join_path, ln, locate, ls_all, modified_time, normalize, pwd, read_lines, readlink, realpath, relative_path, stat, stem, strings, symlink, temp_dir, touch, tree, write_lines, xxd",
      "patterns": [
        {
          "name": "support.function.fs.xell",
          "match": "\\b(cat|chgrp|chmod|chown|created_time|disk_free|disk_usage|extension|file_diff|find|find_regex|glob|hardlink|home_dir|is_absolute|is_symlink|join_path|ln|locate|ls_all|modified_time|normalize|pwd|read_lines|readlink|realpath|relative_path|stat|stem|strings|symlink|temp_dir|touch|tree|write_lines|xxd)\\b(?=\\s*\\()"
        }
      ]
    },
    "generator-builtins": {
      "comment": "GENERATOR builtins: gen_collect, is_exhausted, next",
      "patterns": [
        {
          "name": "support.function.generator.xell",
          "match": "\\b(gen_collect|is_exhausted|next)\\b(?=\\s*\\()"
        }
      ]
    },
    "hash-builtins": {
      "comment": "HASH builtins: hash, hash_seed, hash_seed, hash_seed, is_hashable",
      "patterns": [
        {
          "name": "support.function.hash.xell",
          "match": "\\b(hash|hash_seed|hash_seed|hash_seed|is_hashable)\\b(?=\\s*\\()"
        }
      ]
    },
    "io-builtins": {
      "comment": "IO builtins: exit, input, print",
      "patterns": [
        {
          "name": "support.function.builtin.xell",
          "match": "\\b(exit|input|print)\\b(?=\\s*\\()"
        }
      ]
    },
    "json-builtins": {
      "comment": "JSON builtins: csv_parse, csv_read, csv_write, json_parse, json_pretty, json_read, json_stringify, json_write, toml_read, yaml_read",
      "patterns": [
        {
          "name": "support.function.json.xell",
          "match": "\\b(csv_parse|csv_read|csv_write|json_parse|json_pretty|json_read|json_stringify|json_write|toml_read|yaml_read)\\b(?=\\s*\\()"
        }
      ]
    },
    "list-builtins": {
      "comment": "LIST builtins: avg, enumerate, first, flatten, insert, last, max, min, remove_val, shift, size, slice, sort, sort_desc, sum, unique, unshift, zip, zip_longest",
      "patterns": [
        {
          "name": "support.function.list.xell",
          "match": "\\b(avg|enumerate|first|flatten|insert|last|max|min|remove_val|shift|size|slice|sort|sort_desc|sum|unique|unshift|zip|zip_longest)\\b(?=\\s*\\()"
        }
      ]
    },
    "map-builtins": {
      "comment": "MAP builtins: delete_key, entries, from_entries, get, merge",
      "patterns": [
        {
          "name": "support.function.map.xell",
          "match": "\\b(delete_key|entries|from_entries|get|merge)\\b(?=\\s*\\()"
        }
      ]
    },
    "math-builtins": {
      "comment": "MATH builtins: abs, acos, acosh, acot, acoth, acsc, acsch, asec, asech, asin, asinh, atan, atan2, atanh, bin, ceil, clamp, cos, cosh, cot, coth, csc, csch, floor, hex, is_inf, is_nan, log, log10, mod, pow, random, random_choice, random_int, round, sec, sech, sin, sinh, sqrt, tan, tanh, to_float, to_int",
      "patterns": [
        {
          "name": "support.function.math.xell",
          "match": "\\b(abs|acos|acosh|acot|acoth|acsc|acsch|asec|asech|asin|asinh|atan|atan2|atanh|bin|ceil|clamp|cos|cosh|cot|coth|csc|csch|floor|hex|is_inf|is_nan|log|log10|mod|pow|random|random_choice|random_int|round|sec|sech|sin|sinh|sqrt|tan|tanh|to_float|to_int)\\b(?=\\s*\\()"
        }
      ]
    },
    "network-builtins": {
      "comment": "NETWORK builtins: dns_lookup, download, host_lookup, http_delete, http_get, http_post, http_put, ifconfig, ip_cmd, iptables, local_ip, nc, netstat, nslookup, ping, public_ip, route, rsync, ss, telnet_connect, traceroute, ufw, whois",
      "patterns": [
        {
          "name": "support.function.network.xell",
          "match": "\\b(dns_lookup|download|host_lookup|http_delete|http_get|http_post|http_put|ifconfig|ip_cmd|iptables|local_ip|nc|netstat|nslookup|ping|public_ip|route|rsync|ss|telnet_connect|traceroute|ufw|whois)\\b(?=\\s*\\()"
        }
      ]
    },
    "os-builtins": {
      "comment": "OS builtins: abspath, append, basename, cd, cp, cwd, dirname, env_get, env_has, env_set, env_unset, exists, exit_code, ext, file_size, is_dir, is_file, ls, mkdir, mv, pid, read, rm, run, run_capture, set_e, unset_e, write",
      "patterns": [
        {
          "name": "support.function.builtin.os.xell",
          "match": "\\b(abspath|append|basename|cd|cp|cwd|dirname|env_get|env_has|env_set|env_unset|exists|exit_code|ext|file_size|is_dir|is_file|ls|mkdir|mv|pid|read|rm|run|run_capture|set_e|unset_e|write)\\b(?=\\s*\\()"
        }
      ]
    },
    "process-builtins": {
      "comment": "PROCESS builtins: arch, bg, exec_proc, fg, getuid, hostname, id, is_root, jobs, kill, kill_name, lsof, nice, nohup, os_name, pgrep, pidof, pkill, ppid, ps, pstree, run_timeout, signal_send, spawn, strace, sys_info, time_cmd, uname, uptime, wait_pid, watch, whoami",
      "patterns": [
        {
          "name": "support.function.process.xell",
          "match": "\\b(arch|bg|exec_proc|fg|getuid|hostname|id|is_root|jobs|kill|kill_name|lsof|nice|nohup|os_name|pgrep|pidof|pkill|ppid|ps|pstree|run_timeout|signal_send|spawn|strace|sys_info|time_cmd|uname|uptime|wait_pid|watch|whoami)\\b(?=\\s*\\()"
        }
      ]
    },
    "regex-builtins": {
      "comment": "REGEX builtins: regex_find, regex_find_all, regex_groups, regex_match, regex_match_full, regex_replace, regex_replace_all, regex_split",
      "patterns": [
        {
          "name": "support.function.regex.xell",
          "match": "\\b(regex_find|regex_find_all|regex_groups|regex_match|regex_match_full|regex_replace|regex_replace_all|regex_split)\\b(?=\\s*\\()"
        }
      ]
    },
    "shell-builtins": {
      "comment": "SHELL builtins: alias, clear, env_list, error, export_env, false_val, history, history_add, logout, man, printenv, reset, set_env, source_file, true_val, type_cmd, unalias, whereis, which, yes_cmd",
      "patterns": [
        {
          "name": "support.function.shell.xell",
          "match": "\\b(alias|clear|env_list|error|export_env|false_val|history|history_add|logout|man|printenv|reset|set_env|source_file|true_val|type_cmd|unalias|whereis|which|yes_cmd)\\b(?=\\s*\\()"
        }
      ]
    },
    "string-builtins": {
      "comment": "STRING builtins: char_at, count, ends_with, index_of, is_alpha, is_empty, is_numeric, join, lines, lower, pad_end, pad_start, repeat, replace, replace_first, reverse, split, starts_with, substr, to_chars, trim, trim_end, trim_start, upper",
      "patterns": [
        {
          "name": "support.function.string.xell",
          "match": "\\b(char_at|count|ends_with|index_of|is_alpha|is_empty|is_numeric|join|lines|lower|pad_end|pad_start|repeat|replace|replace_first|reverse|split|starts_with|substr|to_chars|trim|trim_end|trim_start|upper)\\b(?=\\s*\\()"
        }
      ]
    },
    "sysmon-builtins": {
      "comment": "SYSMON builtins: cal, cpu_count, cpu_usage, date_str, dmesg, fdisk, free, iostat, journalctl, last_logins, lsblk, lscpu, lsmem, lspci, lsusb, mem_free, mem_total, mem_used, mount_fs, mpstat, sar, ulimit_info, umount_fs, vmstat, w_cmd",
      "patterns": [
        {
          "name": "support.function.sysmon.xell",
          "match": "\\b(cal|cpu_count|cpu_usage|date_str|dmesg|fdisk|free|iostat|journalctl|last_logins|lsblk|lscpu|lsmem|lspci|lsusb|mem_free|mem_total|mem_used|mount_fs|mpstat|sar|ulimit_info|umount_fs|vmstat|w_cmd)\\b(?=\\s*\\()"
        }
      ]
    },
    "textproc-builtins": {
      "comment": "TEXTPROC builtins: awk, cut, grep, grep_recursive, grep_regex, head, less, more, patch, sed, sort_file, tail, tail_follow, tee, tr, uniq, wc, xargs",
      "patterns": [
        {
          "name": "support.function.textproc.xell",
          "match": "\\b(awk|cut|grep|grep_recursive|grep_regex|head|less|more|patch|sed|sort_file|tail|tail_follow|tee|tr|uniq|wc|xargs)\\b(?=\\s*\\()"
        }
      ]
    },
    "type-builtins": {
      "comment": "TYPE builtins: complex, conjugate, float, imag, int, magnitude, num, real, str, type, type, typeof",
      "patterns": [
        {
          "name": "support.type.conversion.xell",
          "match": "\\b(complex|conjugate|float|imag|int|magnitude|num|real|str|type|type|typeof)\\b(?=\\s*\\()"
        }
      ]
    },
    "util-builtins": {
      "comment": "UTIL builtins: assert, format",
      "patterns": [
        {
          "name": "support.function.builtin.xell",
          "match": "\\b(assert|format)\\b(?=\\s*\\()"
        }
      ]
    },
    "arrow-access": {
      "comment": "-> map key access operator",
      "patterns": [
        {
          "name": "keyword.operator.access.xell",
          "match": "->"
        }
      ]
    },
    "comparison-operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.xell",
          "match": "==|!=|<=|>=|<|>"
        }
      ]
    },
    "increment-operators": {
      "patterns": [
        {
          "name": "keyword.operator.increment.xell",
          "match": "\\+\\+|--"
        }
      ]
    },
    "assignment-operator": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.xell",
          "match": "="
        }
      ]
    },
    "arithmetic-operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.xell",
          "match": "\\+|-|\\*|/|%"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.xell",
          "match": "(?<![a-zA-Z_\\.])\\d+\\.\\d+"
        },
        {
          "name": "constant.numeric.integer.xell",
          "match": "(?<![a-zA-Z_\\.])\\d+(?!\\.\\d)"
        }
      ]
    },
    "method-call": {
      "comment": ".name( \u2014 method call via dot",
      "patterns": [
        {
          "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.method.xell"
            }
          }
        }
      ]
    },
    "function-call": {
      "comment": "name( \u2014 function call",
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.xell"
            }
          }
        }
      ]
    },
    "semicolon-terminator": {
      "patterns": [
        {
          "name": "punctuation.terminator.block.xell",
          "match": "^\\s*;\\s*$"
        }
      ]
    },
    "dot-terminator": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.xell",
          "match": "\\.(?=\\s*$|\\s*#)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.round.xell",
          "match": "[()]"
        },
        {
          "name": "punctuation.bracket.square.xell",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.bracket.curly.xell",
          "match": "[{}]"
        },
        {
          "name": "punctuation.separator.comma.xell",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.xell",
          "match": ":"
        }
      ]
    },
    "identifiers": {
      "comment": "Catch-all: remaining identifiers \u2192 variable color",
      "patterns": [
        {
          "name": "variable.other.xell",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}

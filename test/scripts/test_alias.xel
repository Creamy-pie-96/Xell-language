# =============================================================================
# Module System - Alias (as) keyword tests
# =============================================================================

print("=== Alias (as) tests ===")

# bring single function with alias
bring json_parse from "json" as parse_json
result = parse_json("[1, 2, 3]")
print(len(result))
print(type(result))

# bring with alias - original name should NOT work
# (this would error: json_parse("[1]"))

# bring another function with alias
bring json_stringify from "json" as to_json
print(to_json([10, 20]))

# bring regex with alias
bring regex_match from "regex" as matches
print(matches("hello world", "hello"))

bring regex_find from "regex" as find_pattern
print(find_pattern("abc 123 xyz", "[0-9]+"))

# bring from datetime with alias
bring timestamp from "datetime" as get_ts
t = get_ts()
print(t > 0)

# alias for a 3rd party module function
bring greet from "mylib.xel" as say_hello
print(say_hello("Xell"))

# bring multiple, alias each
bring json_parse from "json" as jp
bring json_stringify from "json" as js
data = jp("[42]")
print(js(data))

print("=== Alias OK ===")

# =============================================================================
# Module System Integration Test - Tier 1
# =============================================================================

print("=== Tier 1: No bring needed ===")

# IO
print("print works")

# Math
print(floor(3.7))
print(sqrt(16))
print(abs(-5))

# String
print(upper("hello"))
print(len("abc"))

# Collection
x = [3, 1, 2]
print(len(x))
push(x, 4)
print(x)

# Type
print(type(42))
print(type("hello"))

# Map / filter / reduce
nums = [1, 2, 3, 4, 5]
fn double(n):
    give n * 2
;
doubled = map(nums, double)
print(doubled)

fn is_even(n):
    give n % 2 == 0
;
evens = filter(nums, is_even)
print(evens)

fn add(a, b):
    give a + b
;
total = reduce(nums, add, 0)
print(total)

# Math constants
print(PI > 3.14)
print(E > 2.71)

print("=== Tier 1 OK ===")

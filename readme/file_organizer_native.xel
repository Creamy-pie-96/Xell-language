# =============================================================================
# Reiko File Organizer — Native Xell Implementation
# =============================================================================
#
# Usage:
#   xell file_organizer_native.xel                    # Interactive mode
#   xell file_organizer_native.xel --help / -h        # Show help
#   xell file_organizer_native.xel -test              # Create flat test files only
#   xell file_organizer_native.xel --test             # Create flat test files + prompt sort
#   xell file_organizer_native.xel -test-recursive [N]   # Create recursive test only
#   xell file_organizer_native.xel --test-recursive [N]  # Create recursive test + prompt sort
# =============================================================================

# ── Category Definitions ──────────────────────────────────────────────────────

n_category_order = ["Images", "Docs", "Archives", "Audio", "Video", "Code", "Fonts", "System", "Design", "Others"]

n_categories = {
    "Images":   ["png", "jpg", "jpeg", "gif", "bmp", "tiff", "svg", "webp", "heic", "raw", "cr2", "nef", "arw", "dng"],
    "Docs":     ["txt", "md", "log", "pdf", "doc", "docx", "ppt", "pptx", "xls", "xlsx", "csv", "epub", "mobi", "azw3", "html", "css", "xml", "json", "yaml", "yml", "rtf"],
    "Archives": ["zip", "rar", "7z", "tar", "gz", "bz2", "tgz", "iso", "dmg", "apk"],
    "Audio":    ["mp3", "wav", "flac", "aac", "ogg", "m4a", "wma", "aiff"],
    "Video":    ["mp4", "mkv", "avi", "mov", "flv", "webm", "mpg", "mpeg", "3gp", "wmv"],
    "Code":     ["cpp", "c", "java", "swift", "kotlin", "cs", "go", "rs", "rb", "pl", "lua", "h", "hpp", "hxx", "hh", "tpp", "inl", "ipp", "py", "pyw", "pyi", "js", "ts", "tsx", "jsx", "php", "sh", "bash", "zsh", "fish", "ps1", "psm1", "psd1", "bat", "cmd", "sql"],
    "Fonts":    ["ttf", "otf", "woff", "woff2"],
    "System":   ["exe", "bin", "dll", "deb", "rpm", "dmg", "app", "bak", "tmp", "env", "conf", "ini"],
    "Design":   ["psd", "ai", "sketch", "xd", "fig", "prproj", "aep", "audproj"],
    "Others":   ["torrent", "dat"]
}

# ── Subcategory Order ─────────────────────────────────────────────────────────

n_subcat_order = {
    "Images":   ["Photos", "Graphics"],
    "Docs":     ["Text", "Office", "PDF", "Ebooks", "Data", "Web", "Logs"],
    "Archives": ["Compressed", "DiskImage", "Mobile"],
    "Audio":    ["Lossless", "Lossy"],
    "Video":    ["Common", "Web", "Legacy"],
    "Code":     ["Source", "Headers", "Python", "Web", "Scripts", "Database"],
    "Fonts":    ["Desktop", "Web"],
    "System":   ["Executables", "Packages", "Config", "Temp"],
    "Design":   ["Adobe", "UI_UX"],
    "Others":   []
}

# ── Subcategory Extension Maps ────────────────────────────────────────────────

n_subcategories = {
    "Images": {
        "Photos":   ["jpg", "jpeg", "heic", "raw", "cr2", "nef", "arw", "dng"],
        "Graphics": ["png", "gif", "bmp", "tiff", "webp", "svg"]
    },
    "Docs": {
        "Text":   ["txt", "md", "rtf"],
        "Office": ["doc", "docx", "ppt", "pptx", "xls", "xlsx"],
        "PDF":    ["pdf"],
        "Ebooks": ["epub", "mobi", "azw3"],
        "Data":   ["csv", "xml", "json", "yaml", "yml"],
        "Web":    ["html", "css"],
        "Logs":   ["log"]
    },
    "Archives": {
        "Compressed": ["zip", "rar", "7z", "gz", "bz2", "tgz", "tar"],
        "DiskImage":  ["iso", "dmg"],
        "Mobile":     ["apk"]
    },
    "Audio": {
        "Lossless": ["wav", "flac", "aiff"],
        "Lossy":    ["mp3", "aac", "ogg", "m4a", "wma"]
    },
    "Video": {
        "Common": ["mp4", "mkv", "mov", "avi"],
        "Web":    ["webm", "flv"],
        "Legacy": ["mpg", "mpeg", "3gp", "wmv"]
    },
    "Code": {
        "Source":   ["cpp", "c", "java", "swift", "kotlin", "cs", "go", "rs", "rb", "pl", "lua"],
        "Headers":  ["h", "hpp", "hxx", "hh", "tpp", "inl", "ipp"],
        "Python":   ["py", "pyw", "pyi"],
        "Web":      ["js", "ts", "tsx", "jsx", "php"],
